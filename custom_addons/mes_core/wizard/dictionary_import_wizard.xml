<odoo>
    <record id="view_mes_import_dictionaries_wizard_form" model="ir.ui.view">
        <field name="name">mes.dictionary.import.wizard.form</field>
        <field name="model">mes.dictionary.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Configuration CSV">
                <group>
                    <field name="import_mode" widget="radio" invisible="context.get('default_import_mode')"/>
                    <field name="import_type" widget="radio" invisible="context.get('default_import_type')"/>
                    <field name="machine_id" invisible="import_mode != 'machine'" required="import_mode == 'machine'"/>
                    <field name="file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>
                
                <div invisible="import_type != 'event'" class="alert alert-info" role="alert">
                    <p><strong>Alarms / Events CSV Format (delimiter ';'):</strong></p>
                    <p>AlarmCode;Description;DefaultOPCTag;DefaultPLCValue;ParentName</p>
                </div>
                
                <div invisible="import_type != 'count'" class="alert alert-warning" role="alert">
                    <p><strong>Rejections / Counts CSV Format (delimiter ';'):</strong></p>
                    <p>EventCode;Description;Wheel;Module;Tag;ParentName</p>
                </div>
                
                <footer>
                    <button name="do_import" string="Import" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mes_import_dictionaries" model="ir.actions.act_window">
        <field name="name">Import Global Dictionaries</field>
        <field name="res_model">mes.dictionary.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_import_mode': 'global'}</field>
    </record>

    <menuitem id="menu_mes_import_dictionaries"
              name="Import Dictionaries CSV"
              parent="menu_mes_configuration" 
              action="action_mes_import_dictionaries"
              sequence="100"/>
</odoo>